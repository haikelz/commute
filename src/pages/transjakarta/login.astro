---
import Layout from "@/layouts/layout.astro";

function safeNext(raw: string | null): string {
  const fallback = "/transjakarta";
  if (!raw || !raw.startsWith("/")) return fallback;
  if (raw.startsWith("//")) return fallback;
  if (!raw.startsWith("/transjakarta")) return fallback;
  if (raw.startsWith("/transjakarta/login")) return fallback;
  return raw;
}

const next = safeNext(Astro.url.searchParams.get("next"));
---

<Layout title="Masuk" description="Login untuk mengakses fiturTransJakarta">
  <div
    class="relative z-10 mx-auto flex min-h-[calc(100vh-3.5rem)] max-w-md flex-col justify-center px-4 py-12 sm:px-6"
  >
    <div
      class="rounded-2xl border border-white/10 bg-white/4 p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.06)_inset] backdrop-blur-md sm:p-8"
    >
      <h1
        class="text-balance bg-linear-to-br from-white via-zinc-100 to-zinc-400 bg-clip-text text-2xl font-semibold tracking-tight text-transparent"
      >
        Login
      </h1>
      <p class="mt-2 text-sm text-zinc-400">Masukkan email dan password</p>
      <form id="tj-login" class="mt-6 space-y-4">
        <div>
          <label
            for="tj-email"
            class="mb-1.5 block text-xs font-medium text-zinc-500 uppercase"
            >Email</label
          >
          <input
            id="tj-email"
            name="email"
            type="email"
            autocomplete="username"
            required
            class="w-full rounded-xl border border-white/10 bg-black/30 px-3 py-2.5 text-sm text-zinc-100 outline-none ring-fuchsia-500/30 placeholder:text-zinc-600 focus:border-fuchsia-500/40 focus:ring-2"
            placeholder="nama@email.com"
          />
        </div>
        <div>
          <label
            for="tj-password"
            class="mb-1.5 block text-xs font-medium text-zinc-500 uppercase"
            >Password</label
          >
          <input
            id="tj-password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            class="w-full rounded-xl border border-white/10 bg-black/30 px-3 py-2.5 text-sm text-zinc-100 outline-none ring-fuchsia-500/30 placeholder:text-zinc-600 focus:border-fuchsia-500/40 focus:ring-2"
          />
        </div>
        <p id="tj-login-err" class="hidden text-sm text-red-300"></p>
        <button
          type="submit"
          id="tj-submit"
          class="w-full rounded-xl border border-fuchsia-500/40 bg-fuchsia-500/15 px-4 py-2.5 text-sm font-medium text-fuchsia-100 transition-colors hover:bg-fuchsia-500/25 disabled:opacity-50"
        >
          Masuk
        </button>
      </form>
    </div>
  </div>
  <script is:inline define:vars={{ next }}>
    (function () {
      const form = document.getElementById("tj-login");
      const err = document.getElementById("tj-login-err");
      const submit = document.getElementById("tj-submit");
      if (!form || !err || !submit) return;
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        err.classList.add("hidden");
        submit.setAttribute("disabled", "true");
        const fd = new FormData(form);
        const email = String(fd.get("email") || "");
        const password = String(fd.get("password") || "");
        try {
          const res = await fetch("/api/transjakarta/auth/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password }),
          });
          const data = await res.json().catch(function () {
            return {};
          });
          if (res.ok) {
            window.location.href = next;
            return;
          }
          err.textContent =
            typeof data.error === "string"
              ? data.error
              : "Gagal masuk. Periksa email dan password.";
          err.classList.remove("hidden");
        } catch {
          err.textContent = "Jaringan bermasalah. Coba lagi.";
          err.classList.remove("hidden");
        } finally {
          submit.removeAttribute("disabled");
        }
      });
    })();
  </script>
</Layout>
